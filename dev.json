{
	"name":"dev_build",
	"libs":{
		"cbpp":{
			"include":"include/cbpp",
			"static":"static",
			"lib":"lib",
			
			"out_dll":"bin",
			"out_lib":"lib",
			
			"obj":"src/cbpp/obj",
			
			"src":[
				"src/cbpp/vec2.cpp", "src/cbpp/mesh.cpp", "src/cbpp/misc.cpp",
				"src/cbpp/physobj.cpp", "src/cbpp/logs.cpp",
				"src/cbpp/bbox/aabb.cpp", "src/cbpp/bbox/obb.cpp", "src/cbpp/matrix.cpp",
				"src/cbpp/btable.cpp"
			],
			
			"add_static":[],
			"add_lib":[],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		},
		
		"cbasset":{
			"include":"include/cbpp",
			"lib":"lib",
			"static":"static",
			
			"out_dll":"bin",
			"out_lib":"lib",
			
			"obj":"src/cbasset/obj",
			
			"src":[
				"src/cbasset/font.cpp", "src/cbasset/texture.cpp",
				"src/cbasset/sound.cpp", "src/cbasset/cmfbase.cpp", 
				
				"src/cbasset/entity/BaseEntity.cpp",
				
				"src/cbasset/json/json_reader.cpp", "src/cbasset/json/json_value.cpp",
				"src/cbasset/json/json_writer.cpp"
			],

			"add_static":[],
			"add_lib":["cbpp.lib", "cbdraw.lib", "SDL2_ttf.lib",
						"freetype.lib", "SDL2.lib", "SDL2_image.lib", "SDL2_mixer.lib",
						"SDL2_net.lib"],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		},
		
		"cbdraw":{
			"include":"include/cbpp",
			"lib":"lib",
			"static":"static",
			
			"out_dll":"bin",
			"out_lib":"lib",
			
			"obj":"src/cbdraw/obj",
			
			"src":[
				"src/cbdraw/window.cpp", "src/cbdraw/gpu_surf.cpp",
				"src/cbdraw/sdl_gfx/SDL2_framerate.c",
				"src/cbdraw/sdl_gfx/SDL2_gfxPrimitives.c", "src/cbdraw/sdl_gfx/SDL2_imageFilter.c",
				"src/cbdraw/sdl_gfx/SDL2_rotozoom.c"
			],

			"add_static":[],
			"add_lib":["cbpp.lib", "cbdraw.lib",
						"SDL2_ttf.lib", "cbasset.lib",
						"SDL2.lib", "SDL2_image.lib",
						"SDL2_net.lib"
			],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		},
		
		"SDL2_net":{
			"include":"include/cbpp/SDL2",
			"lib":"lib",
			"static":"static",
			
			"out_dll":"bin",
			"out_lib":"lib",
			
			"obj":"src/sdl2_net/obj",
			
			"src":[
				"src/sdl2_net/SDLnet.c", "src/sdl2_net/SDLnetselect.c",
				"src/sdl2_net/SDLnetTCP.c", "src/sdl2_net/SDLnetUDP.c"
			],

			"add_static":["wsock32","iphlpapi"],
			"add_lib":["SDL2.lib"],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		},
		
		"cbsv":{
			"include":"include/cbpp",
			"static":"static",
			"lib":"lib",
			
			"out_dll":"bin",
			"out_lib":"lib",
			
			"obj":"src/cbsv/obj",
			
			"src":[
				"src/cbsv/sv_cluster.cpp", "src/cbsv/sv_user.cpp",
				"src/cbsv/sv_main.cpp"
			],
			
			"add_static":[],
			"add_lib":["SDL2_net.lib", "cbpp.lib"],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		}
	},
	
	"bin":{		
		"sv_main":{
			"include":"include/cbpp",
			"lib":"lib",
			"static":"static",
			"out":"bin",
			"obj":"src/sv_main/obj",
			
			"src":[
				"src/sv_main/main.cpp"
			],

			"add_static":[],
			"add_lib":["cbpp.lib", "cbdraw.lib", "SDL2_ttf.lib",
						"freetype.lib", "cbasset.lib", "SDL2_mixer.lib",
						"SDL2.lib", "SDL2_image.lib", "SDL2_net.lib",
						"cbsv.lib"],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		},
		
		"cl_main":{
			"include":"include/cbpp",
			"lib":"lib",
			"static":"static",
			"out":"bin",
			"obj":"src/cl_main/obj",
			
			"src":[
				"src/cl_main/main.cpp", "src/cl_main/render.cpp"
			],

			"add_static":[],
			"add_lib":["cbpp.lib", "cbdraw.lib", "SDL2_ttf.lib",
						"freetype.lib", "cbasset.lib", "SDL2_mixer.lib",
						"SDL2.lib", "SDL2_image.lib", "SDL2_net.lib",
						"cbsv.lib"],
			
			"compiler_params":"-m64",
			"builder_params":"-m64"
		}
	}
}